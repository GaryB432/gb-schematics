{
  "name": "@gb-schematics/schematics",
  "version": "6.0.0-alpha.1",
  "description": "GB Schematics collection",
  "type": "module",
  "schematics": "./dist/collection.json",
  "scripts": {
    "build": "node ../../tools/generate-schema-types.mjs src && rm -rf dist && tsc && copyfiles -u 1 \"src/**/*.json\" \"src/**/files/**/*\" dist",
    "lint": "eslint src --ext .ts",
    "test": "pnpm run build && tsc -p tsconfig.spec.json && node --test dist/**/*_spec.js"
  },
  "dependencies": {
    "@angular-devkit/core": "^19.2.27",
    "@angular-devkit/schematics": "^19.2.27",
    "semver": "^7.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/GaryB432/gb-schematics/issues",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "url": "git+https://github.com/GaryB432/gb-schematics.git"
  }
}
