{
  "$schema": "https://raw.githubusercontent.com/angular/angular-cli/main/packages/angular_devkit/schematics/collection-schema.json",
  "schematics": {
    "bump": {
      "description": "Bump package version using semver increment rules",
      "factory": "./bump/index#bump",
      "schema": "./bump/schema.json"
    },
    "module": {
      "description": "Add Class or general Module",
      "schema": "./module/schema.json",
      "factory": "./module"
    },
    "sveltekit-component": {
      "description": "Add a component to your sveltekit project",
      "schema": "./sveltekit-component/schema.json",
      "factory": "./sveltekit-component"
    },
    "sveltekit-route": {
      "description": "Add a route to your sveltekit project",
      "schema": "./sveltekit-route/schema.json",
      "factory": "./sveltekit-route"
    }
  }
}
